DB_HOST=localhost
DB_PORT=1433
DB_NAME=HaoHanDB
DB_USERNAME=sa
DB_PASSWORD=YourPassword123

# Discord Webhook URL for logs
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-id/your-webhook-token

# RCON Configuration
RCON_HOST=127.0.0.1
RCON_PORT=25575
RCON_PASSWORD=your_rcon_password

# PayOS credentials
PAYOS_CLIENT_ID=your_payos_client_id
PAYOS_API_KEY=your_payos_api_key
PAYOS_CHECKSUM_KEY=your_payos_checksum_key

# Game Server Token (For game to API communication security)
GAME_SERVER_TOKEN=super_secure_server_token_123

# JWT secret key for signing
JWT_SECRET=super_secret_jwt_key_987

# Discord OAuth2 Configuration (For Web Portal Integration)
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=http://localhost:3000/vi/discord/callback

# Discord Guild (Server) Configuration (For server membership verification & roles sync)
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_GUILD_ID=your_discord_guild_id

# Cloudinary Configuration (For uploading Discord avatars)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
